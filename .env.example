# ===========================================
# Kocaeli Haber Haritası - Ortam Değişkenleri
# ===========================================
# Bu dosyayı .env olarak kopyalayıp değerlerinizi girin:
# cp .env.example .env

# MongoDB Bağlantısı
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=kocaeli_haber_haritasi

# Google Maps API Anahtarı
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Google Geocoding API Anahtarı
GOOGLE_GEOCODING_API_KEY=YOUR_GOOGLE_GEOCODING_API_KEY_HERE

# Flask Ayarları
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# Scraping Ayarları
SCRAPING_DAYS=3
REQUEST_TIMEOUT=30
REQUEST_DELAY=2
